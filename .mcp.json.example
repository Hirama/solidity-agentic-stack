{
  "_comment": "MCP = the agent's hands. These servers give Claude tools to read chain state, simulate txs, and inspect contracts — without ever touching a key or broadcasting. Copy to .mcp.json and fill in your values.",
  "mcpServers": {
    "foundry": {
      "_comment": "Foundry MCP (community, github.com/alexbakers/foundry-mcp) — cast/forge primitives: read storage, call functions, decode calldata.",
      "command": "npx",
      "args": ["-y", "foundry-mcp"],
      "env": {
        "RPC_URL": "${RPC_MAINNET}"
      }
    },
    "blockscout": {
      "_comment": "Blockscout MCP = on-chain read access. Address info, txs, ABIs, token transfers — all read-only.",
      "url": "https://mcp.blockscout.com/mcp"
    }
  }
}
